{
	"name": "obsidian-mail-importer",
	"version": "1.0.0",
	"description": "Import emails from an IMAP mailbox into your Obsidian vault as Markdown notes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest --run",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.40",
		"@types/turndown": "^5.0.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"fast-check": "^4.7.0",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"imapflow": "^1.3.3",
		"mailparser": "^3.9.8",
		"obsidian": "latest",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2"
	}
}
